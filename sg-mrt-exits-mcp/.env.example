# ── Required: Data source API ─────────────────────────────────────────────────
# Point these at your own API that serves the LTA MRT Station Exit GeoJSON data.
# See README.md → "About the Data Source" for dataset details and compatibility
# requirements. There is no shared public endpoint — you must provide your own.
API_BASE_URL=https://your-api-host.com
API_ENDPOINT_PATH=/your/endpoint/path
API_USERNAME=your_username
API_TOKEN=your_token

# ── Required for HTTP deployment ──────────────────────────────────────────────
# Set to streamable-http (recommended) or sse when running as an HTTP service.
# Leave unset or set to stdio for local desktop clients (Claude Desktop, etc.).
MCP_TRANSPORT=streamable-http

# ── Optional: Performance tuning ──────────────────────────────────────────────
# CACHE_TTL_SECONDS=300      # How long to cache the full exit dataset (seconds)
# API_MAX_CONCURRENCY=5      # Max simultaneous outbound HTTP requests

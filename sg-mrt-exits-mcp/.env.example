# ── api.jael.ee credentials (required) ────────────────────────────────────────
# Register at https://api.jael.ee to obtain your credentials.
API_BASE_URL=https://api.jael.ee
API_USERNAME=your_email@address.com
API_TOKEN=t_your_token_here

# ── Transport (optional, default: stdio) ──────────────────────────────────────
# Set to streamable-http or sse when deploying as an HTTP service.
# Leave unset (or set to stdio) for local clients (Claude Desktop, Claude API).
# MCP_TRANSPORT=streamable-http

# ── API endpoint path (optional override) ─────────────────────────────────────
# API_ENDPOINT_PATH=/JLEE/sg_lta_mrt_station_exit_geojson_api

# ── Performance tuning (optional) ─────────────────────────────────────────────
# CACHE_TTL_SECONDS=300
# API_MAX_CONCURRENCY=5
